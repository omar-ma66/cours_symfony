{% extends 'base.html.twig' %}

{% block title %}Author{% endblock %}

{% block body %}
    <h1>Auteur</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ author.id }}</td>
            </tr>
            <tr>
                <th>FirstName</th>
                <td>{{ author.firstName }}</td>
            </tr>
            <tr>
                <th>LastName</th>
                <td>{{ author.lastName }}</td>
            </tr>
        </tbody>
    </table>

            <table>
                    <tr><th>Titre(s)</th></tr>
                     {% for book in author.books %}
                        <tr><td>{{ book.title }} </td></tr>
                        {% else %}
                        <p> pas de livre </p>
                     {% endfor %}

            </table>
    <a href="{{ path('app_author_index') }}">Retour a la liste</a> |

    <a href="{{ path('app_author_edit', {'id': author.id}) }}">edit</a>

    {{ include('author/_delete_form.html.twig') }}
{% endblock %}
