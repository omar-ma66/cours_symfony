            {% extends 'base.html.twig' %}

{% block title %}Bibliotech — {{ book.title }}{% endblock %}

{% block body %}
    <a href="{{ path('app_book_index') }}"
       class="text-indigo-600 hover:underline text-sm">← Retour à la liste</a>

    <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-8 mt-4">
        <h1 class="text-3xl font-bold text-gray-800 mb-2">📖 {{ book.title }}</h1>

        <p class="text-gray-600 mb-4">
            ✍️ <a href="{{ path('app_author_show', {id: book.author.id}) }}"
                  class="text-indigo-600 hover:underline font-medium">
                {{ book.author.firstName }} {{ book.author.lastName }}
            </a>
        </p>

        {% if book.description %}
            <p class="text-gray-700 mb-4 leading-relaxed">{{ book.description }}</p>
        {% endif %}

        <div class="flex flex-wrap gap-4 text-sm mb-4">
            <span class="bg-gray-100 text-gray-700 px-3 py-1 rounded-full">
                Stock :
                <strong class="{% if book.stock == 0 %}text-red-600{% else %}text-green-600{% endif %}">
                    {{ book.stock }}
                </strong>
            </span>
            {% if book.isbn %}
                <span class="bg-gray-100 text-gray-700 px-3 py-1 rounded-full">ISBN : {{ book.isbn }}</span>
            {% endif %}
        </div>

        {% if book.categories|length > 0 %}
            <div class="flex flex-wrap gap-2 mb-6">
                {% for category in book.categories %}
                    <a href="{{ path('app_select_categorie', {id: category.id}) }}"
                       class="bg-indigo-100 text-indigo-700 hover:bg-indigo-200 text-xs font-medium px-3 py-1 rounded-full transition">
                        🏷️ {{ category.name }}
                    </a>
                {% endfor %}
            </div>
        {% endif %}

        <div class="flex gap-4 mt-6 border-t pt-4">
            <a href="{{ path('app_book_edit', {id: book.id}) }}"
               class="bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2 px-4 rounded-lg transition">
                ✏️ Modifier
            </a>
            <form method="POST" action="{{ path('app_book_delete', {id: book.id}) }}"
                  onsubmit="return confirm('Es-tu sûr de vouloir supprimer « {{ book.title }} » ?')">
                <input type="hidden" name="_token" value="{{ csrf_token('delete-book-' ~ book.id) }}">
                <button type="submit"
                        class="bg-red-100 hover:bg-red-200 text-red-700 font-semibold py-2 px-4 rounded-lg transition cursor-pointer">
                    🗑️ Supprimer
                </button>
            </form>
        </div>
    </div>
{% endblock %}


   
