<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Bibliotech{% endblock %}</title>

        {% block stylesheets %}
        {% endblock %}
    </head>
    <body>
      
        {{ include ('_partials/_header.html.twig') }}
        <main style="padding: 30px; max-width: 960px; margin: 0 auto;">

                    {% for type , messages in app.flashes  %}
                        {%  for message in messages  %}
                          <div style="
                padding: 12px 20px;
                margin-bottom: 15px;
                border-radius: 6px;
                background-color: {% if type == 'success' %}#d4edda{% elseif type == 'error' %}#f8d7da{% else %}#fff3cd{% endif %};
                color: {% if type == 'success' %}#155724{% elseif type == 'error' %}#721c24{% else %}#856404{% endif %};
                border: 1px solid {% if type == 'success' %}#c3e6cb{% elseif type == 'error' %}#f5c6cb{% else %}#ffeeba{% endif %};
            ">
                        {{message}}
            </div>
            {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>

        {{ include ('_partials/_footer.html.twig') }}

        {% block javascripts %}
        {% endblock %}
    </body>
</html>