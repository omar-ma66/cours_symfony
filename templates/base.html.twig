<!DOCTYPE html>
<html lang="fr" class="h-full bg-gray-50">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Bibliotech{% endblock %}</title>  <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        {% block stylesheets %}
          
        {% endblock %}
    </head>
    <body class="flex flex-col min-h-screen text-gray-800">

        {% include '_partials/_header.html.twig' %}

        <main class="flex-1 max-w-5xl mx-auto w-full px-4 py-8">

            {# Messages flash #}
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="mb-4 px-4 py-3 rounded-lg border
                        {% if type == 'success' %}bg-green-50 text-green-800 border-green-300
                        {% elseif type == 'error' %}bg-red-50 text-red-800 border-red-300
                        {% else %}bg-yellow-50 text-yellow-800 border-yellow-300{% endif %}">
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>

        {% include '_partials/_footer.html.twig' %}

        {% block javascripts %}
                {% block importmap  %} {{ importmap('app') }} {% endblock %}
        {% endblock %}
    </body>
</html>